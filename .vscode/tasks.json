{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "qdrant: init",
      "type": "shell",
      "command": "make init",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "qdrant: dev",
      "type": "shell",
      "command": "make dev",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "qdrant: lint",
      "type": "shell",
      "command": "make lint",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "qdrant: format",
      "type": "shell",
      "command": "make format",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "qdrant: typecheck",
      "type": "shell",
      "command": "make typecheck",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "qdrant: test",
      "type": "shell",
      "command": "make test",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "qdrant: test with coverage",
      "type": "shell",
      "command": "make test-coverage",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "qdrant: pre-commit",
      "type": "shell",
      "command": "make pre-commit",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "qdrant: verify",
      "type": "shell",
      "command": "make check",
      "options": { "cwd": "${workspaceFolder}" },
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}
